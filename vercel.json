{
  "version": 2,
  "buildCommand": null,
  "devCommand": null,
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/public/organization-dashboard.html",
      "destination": "/public/dashboard.html",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cdm86.com" }],
      "destination": "https://cdm86.it/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.cdm86.com" }],
      "destination": "https://www.cdm86.it/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "cdm86.io" }],
      "destination": "https://www.cdm86.it/collaboratori/login.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.cdm86.io" }],
      "destination": "https://www.cdm86.it/collaboratori/login.html",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cdm86.io" }],
      "destination": "https://www.cdm86.it/collaboratori/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.cdm86.io" }],
      "destination": "https://www.cdm86.it/collaboratori/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/collaboratori",
      "destination": "/collaboratori/login.html"
    },
    {
      "source": "/collaboratori/",
      "destination": "/collaboratori/login.html"
    },
    {
      "source": "/collaboratori/:page",
      "destination": "/collaboratori/:page"
    },
    {
      "source": "/promo/:slug",
      "destination": "/public/promo-landing.html"
    },
    {
      "source": "/page/([^/]+)",
      "destination": "/public/page.html"
    },
    {
      "source": "/",
      "destination": "/public/promotions.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
